# foreground = ffffff
# background = 282c34

font-family = JetBrains Mono
font-size = 15
theme = Night Owl
background = #04101b
background-opacity = 0.95
foreground = #c8d7e8
cursor-color = #7dd3fc
cursor-text = #03121e
selection-foreground = #dbeafe
selection-background = #1f3a50

# Cold ANSI palette
palette = 0=#07111d
palette = 1=#ff6b7a
palette = 2=#7dd3a7
palette = 3=#c4d88a
palette = 4=#7aa2f7
palette = 5=#b8a5ff
palette = 6=#67e8f9
palette = 7=#c8d7e8
palette = 8=#405064
palette = 9=#ff8fa3
palette = 10=#9ae6b4
palette = 11=#d7e6a3
palette = 12=#9bbcff
palette = 13=#cdbdff
palette = 14=#8ff3ff
palette = 15=#eef6ff

# タイトルバー設定
# 上部のタイトルバー、信号ボタン、タブを非表示
window-decoration = none
macos-titlebar-style = hidden
macos-non-native-fullscreen = true
window-show-tab-bar = never
# プロキシアイコン（フォルダアイコン）を非表示
macos-titlebar-proxy-icon = hidden

# ペイン分割の境界線
split-divider-color = #223041

# 非アクティブペインを暗くしない
unfocused-split-opacity = 1

# メニューバーを隠すフルスクリーントグル
keybind = alt+enter=toggle_fullscreen

# 画面分割: Cmd+, で横分割、Cmd+. で縦分割
keybind = cmd+comma=new_split:right
keybind = cmd+period=new_split:down

# ペイン移動: Cmd+矢印
keybind = cmd+arrow_left=goto_split:left
keybind = cmd+arrow_right=goto_split:right
keybind = cmd+arrow_up=goto_split:up
keybind = cmd+arrow_down=goto_split:down

# タブ移動: Opt+矢印
keybind = alt+left=previous_tab
keybind = alt+right=next_tab

# タブのキーキャップ表示を消す（Cmd+数字のバインドを解除）
keybind = super+1=unbind
keybind = super+2=unbind
keybind = super+3=unbind
keybind = super+4=unbind
keybind = super+5=unbind
keybind = super+6=unbind
keybind = super+7=unbind
keybind = super+8=unbind
keybind = super+9=unbind
